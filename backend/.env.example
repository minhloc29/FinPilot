APP_NAME=AI Financial Copilot
DEBUG=false

# Legacy fields (kept for compatibility)
API_ENDPOINT=
API_KEY=
DEFAULT_MODEL=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=2000

DATABASE_URL=postgresql://user:password@localhost:5432/finpilot
REDIS_URL=redis://localhost:6379
SECRET_KEY=YOUR-RANDOM-SECRET-KEY-MIN-32-CHARS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# -----------------------------------------------
# TradingAgents Agents config
# -----------------------------------------------
TRADINGAGENTS_ENABLED=true
TRADINGAGENTS_LLM_PROVIDER=openai

# Deep model: used by Research Manager and Portfolio Manager (complex reasoning)
TRADINGAGENTS_DEEP_MODEL=gpt-4o

# Quick model: used by individual Analysts (market, news, fundamentals, social)
TRADINGAGENTS_QUICK_MODEL=gpt-4o-mini

TRADINGAGENTS_BACKEND_URL=https://api.openai.com/v1
TRADINGAGENTS_SELECTED_ANALYSTS=market,social,news,fundamentals
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_DISCUSS_ROUNDS=1
TRADINGAGENTS_RESULTS_DIR=./results
TRADINGAGENTS_PROJECT_DIR=

# Data vendor priority (comma-separated, tried left to right on failure)
# Options: vnstock, yfinance, alpha_vantage
TRADINGAGENTS_DATA_VENDORS=vnstock,yfinance

# Optional: provider-specific reasoning settings (leave blank to use defaults)
TRADINGAGENTS_OPENAI_REASONING_EFFORT=
TRADINGAGENTS_GOOGLE_THINKING_LEVEL=
TRADINGAGENTS_ANTHROPIC_EFFORT=

# -----------------------------------------------
# Chat model services (Orchestrator + Formatter)
# -----------------------------------------------
CHAT_INPUT_MODEL_ENABLED=true
CHAT_OUTPUT_MODEL_ENABLED=true

# Model for AI Orchestrator (classifies intent, selects analysts)
CHAT_INPUT_MODEL_NAME=gpt-4o-mini

# Model for output normalization (formats raw agent text for the user)
CHAT_OUTPUT_MODEL_NAME=gpt-4o-mini

CHAT_MODEL_BACKEND_URL=https://api.openai.com/v1
CHAT_MODEL_TIMEOUT_SECONDS=20

# -----------------------------------------------
# Provider API Keys
# -----------------------------------------------
# Required: OpenAI key is used by Agents + Chat models
OPENAI_API_KEY=sk-YOUR-OPENAI-KEY

# Required only if TRADINGAGENTS_DATA_VENDORS includes alpha_vantage
ALPHA_VANTAGE_API_KEY=YOUR-ALPHA-VANTAGE-KEY

# Optional: only needed if switching provider to Anthropic/Google/xAI
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
